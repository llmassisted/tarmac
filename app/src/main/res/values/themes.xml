<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Tarmac" parent="Theme.AppCompat.NoActionBar" />

    <style name="Theme.Tarmac.Leanback" parent="Theme.Leanback.Browse">
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Leanback's settings fragments expect Theme.Leanback (the plain
         variant), NOT Theme.Leanback.Browse — the Browse theme adds a
         header bar that overlaps the preference list. -->
    <style name="Theme.Tarmac.Settings" parent="Theme.Leanback">
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="Theme.Tarmac.Fullscreen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
